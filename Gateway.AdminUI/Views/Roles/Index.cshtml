@using Gateway.AdminUI.Models
@model RolesIndexVm
@{
    ViewData["Title"] = "Roles";
}

<div class="d-flex align-items-end justify-content-between mb-4">
    <div>
        <div class="page-title fs-2">Roles</div>
        <div class="muted">Gestiona roles disponibles para autorización</div>
    </div>

    <button class="btn btn-primary" style="border-radius:14px;" data-bs-toggle="modal" data-bs-target="#createRoleModal">
        <i class="bi bi-plus-lg me-2"></i> Nuevo rol
    </button>
</div>

<div class="card p-3 p-md-4">
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead>
                <tr>
                    <th style="width:60%;">Nombre</th>
                    <th>ID</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model.Roles) {
                    <tr>
                        <td>
                            <span class="badge text-bg-secondary badge-pill">@r.Name</span>
                        </td>
                        <td class="muted small">@r.Id</td>
                        <td class="text-end">
                            <form method="post" action="@Url.Action("Delete","Roles")" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="roleName" value="@r.Name" />
                                <button class="btn btn-sm btn-soft" style="border-radius:12px;" onclick="return confirm('¿Eliminar rol @r.Name?');">
                                    <i class="bi bi-trash3 me-1"></i> Eliminar
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Modal Crear -->
<div class="modal fade" id="createRoleModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content text-white" style="background:#0f1b33;border:1px solid rgba(255,255,255,.10);border-radius:18px;">
            <div class="modal-header border-0">
                <h5 class="modal-title">Crear rol</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" action="@Url.Action("Create","Roles")">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <label class="form-label muted">Nombre</label>
                    <input class="form-control" name="NewRoleName" placeholder="Ej: Manager" />
                    <div class="muted small mt-2">Tip: usa nombres cortos y consistentes (Admin, Operator, Viewer).</div>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-soft" data-bs-dismiss="modal" style="border-radius:14px;">Cancelar</button>
                    <button class="btn btn-primary" style="border-radius:14px;">
                        <i class="bi bi-check2 me-2"></i> Crear
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>