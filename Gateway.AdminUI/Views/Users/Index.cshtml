@using Gateway.AdminUI.Models
@model UsersIndexVm
@{
    ViewData["Title"] = "Usuarios";
}

<div class="d-flex flex-wrap gap-3 align-items-end justify-content-between mb-4">
    <div>
        <div class="page-title fs-2">Usuarios</div>
        <div class="muted">Crea usuarios y gestiona roles</div>
    </div>

    <button class="btn btn-primary" style="border-radius:14px;" data-bs-toggle="modal" data-bs-target="#createUserModal">
        <i class="bi bi-person-plus me-2"></i> Nuevo usuario
    </button>
</div>

<div class="card p-3 p-md-4">
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead>
                <tr>
                    <th>Email</th>
                    <th style="width:30%;">Roles</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var u in Model.Users) {
                    var roles = Model.UserRoles.TryGetValue(u.Id, out var rr) ? rr : new List<string>();
                    <tr>
                        <td>
                            <div class="fw-semibold">@u.Email</div>
                            <div class="muted small">ID: @u.Id</div>
                        </td>

                        <td>
                            <div class="d-flex flex-wrap gap-2">
                                @if (roles.Count == 0) {
                                    <span class="muted small">Sin roles</span>
                                }
                                else {
                                    foreach (var r in roles) {
                                        <span class="badge text-bg-secondary badge-pill">@r</span>
                                    }
                                }
                            </div>

                            <div class="mt-3 d-flex gap-2">
                                <form method="post" action="@Url.Action("AddRole","Users")" class="d-flex gap-2">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="userId" value="@u.Id" />
                                    <select class="form-select form-select-sm" name="roleName" style="min-width:160px;">
                                        @foreach (var r in Model.AllRoles) {
                                            <option value="@r">@r</option>
                                        }
                                    </select>
                                    <button class="btn btn-sm btn-soft" style="border-radius:12px;">
                                        <i class="bi bi-plus-lg me-1"></i> Asignar
                                    </button>
                                </form>

                                <form method="post" action="@Url.Action("RemoveRole","Users")" class="d-flex gap-2">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="userId" value="@u.Id" />
                                    <select class="form-select form-select-sm" name="roleName" style="min-width:160px;">
                                        @foreach (var r in roles) {
                                            <option value="@r">@r</option>
                                        }
                                    </select>
                                    <button class="btn btn-sm btn-soft" style="border-radius:12px;" @(roles.Count == 0 ? "disabled" : "")>
                                        <i class="bi bi-dash-lg me-1"></i> Quitar
                                    </button>
                                </form>
                            </div>
                        </td>

                        <td class="text-end">
                            <form method="post" action="@Url.Action("Delete","Users")" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@u.Id" />
                                <button class="btn btn-sm btn-soft" style="border-radius:12px;" onclick="return confirm('¿Eliminar usuario @u.Email?');">
                                    <i class="bi bi-trash3 me-1"></i> Eliminar
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Modal Crear Usuario -->
<div class="modal fade" id="createUserModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content text-white" style="background:#0f1b33;border:1px solid rgba(255,255,255,.10);border-radius:18px;">
            <div class="modal-header border-0">
                <h5 class="modal-title">Crear usuario</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <form method="post" action="@Url.Action("Create","Users")">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label muted">Email</label>
                        <input class="form-control" name="Email" placeholder="user@company.com" />
                    </div>
                    <div>
                        <label class="form-label muted">Password</label>
                        <input class="form-control" name="Password" type="password" placeholder="Mínimo 8 caracteres" />
                        <div class="muted small mt-2">
                            Consejo: crea una contraseña temporal y luego implementamos “Reset password” en el siguiente sprint.
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-soft" data-bs-dismiss="modal" style="border-radius:14px;">Cancelar</button>
                    <button class="btn btn-primary" style="border-radius:14px;">
                        <i class="bi bi-check2 me-2"></i> Crear
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>