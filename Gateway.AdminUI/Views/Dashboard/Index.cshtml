@{
    ViewData["Title"] = "Dashboard";
}

<div class="d-flex align-items-end justify-content-between mb-4">
    <div>
        <div class="page-title fs-2">Dashboard</div>
        <div class="muted">Administración central de SecureGate</div>
    </div>
    <div class="muted small">
        Session exp: @Context.Session.GetString("ADMIN_JWT_EXP")
    </div>
</div>

<div class="row g-4">
    <div class="col-12 col-lg-6">
        <div class="card p-4">
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <div class="muted small">Usuarios & Roles</div>
                    <div class="fs-5 fw-semibold">Administración de acceso</div>
                </div>
                <i class="bi bi-people fs-2 muted"></i>
            </div>
            <div class="mt-3 muted">
                Crea usuarios, administra roles y controla quién puede acceder a la consola.
            </div>
            <div class="mt-4 d-flex gap-2">
                <a class="btn btn-primary" style="border-radius:14px;" href="@Url.Action("Index", "Users")">
                    Ir a Usuarios
                </a>
                <a class="btn btn-soft" style="border-radius:14px;" href="@Url.Action("Index", "Roles")">
                    Ver Roles
                </a>
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-6">
        <div class="card p-4">
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <div class="muted small">Proxy Management</div>
                    <div class="fs-5 fw-semibold">Rutas & Clusters</div>
                </div>
                <i class="bi bi-diagram-3 fs-2 muted"></i>
            </div>
            <div class="mt-3 muted">
                Próximamente: administración de rutas, clusters y políticas del reverse proxy.
            </div>
            <div class="mt-4">
                <button class="btn btn-soft" style="border-radius:14px;" disabled>
                    Próximamente
                </button>
            </div>
        </div>
    </div>
</div>