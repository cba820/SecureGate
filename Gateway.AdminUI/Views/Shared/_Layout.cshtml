@{
    var isLogged = Context.Session.GetString("ADMIN_JWT") is not null;
    var current = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
}

<!doctype html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - SecureGate Admin</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link href="/css/site.css" rel="stylesheet" />
</head>
<body class="text-white">
    <div class="d-flex app-shell">

        @if (isLogged) {
            <aside class="sidebar p-3 d-flex flex-column">
                <div class="d-flex align-items-center gap-2 mb-4">
                    <div class="rounded-4 d-inline-flex align-items-center justify-content-center"
                         style="width:42px;height:42px;background:rgba(99,102,241,.18);border:1px solid rgba(99,102,241,.25);">
                        <i class="bi bi-shield-lock fs-4"></i>
                    </div>
                    <div>
                        <div class="brand">SecureGate</div>
                        <div class="muted small">Admin Console</div>
                    </div>
                </div>

                <nav class="d-grid gap-2">
                    <a class="nav-pill text-decoration-none @(current == "Dashboard" ? "active" : "")" href="@Url.Action("Index", "Dashboard")">
                        <i class="bi bi-speedometer2 me-2"></i> Dashboard
                    </a>
                    <a class="nav-pill text-decoration-none @(current == "Users" ? "active" : "")" href="@Url.Action("Index", "Users")">
                        <i class="bi bi-people me-2"></i> Usuarios
                    </a>
                    <a class="nav-pill text-decoration-none @(current == "Roles" ? "active" : "")" href="@Url.Action("Index", "Roles")">
                        <i class="bi bi-person-badge me-2"></i> Roles
                    </a>

                    <div class="mt-3 muted small">Próximamente</div>
                    <a class="nav-pill text-decoration-none disabled" href="#" tabindex="-1" aria-disabled="true">
                        <i class="bi bi-diagram-3 me-2"></i> Proxy Routes
                    </a>
                    <a class="nav-pill text-decoration-none disabled" href="#" tabindex="-1" aria-disabled="true">
                        <i class="bi bi-hdd-network me-2"></i> Clusters
                    </a>
                </nav>

                <div class="mt-auto pt-4">
                    <form method="post" action="@Url.Action("Logout","Auth")">
                        @Html.AntiForgeryToken()
                        <button class="btn btn-soft w-100">
                            <i class="bi bi-box-arrow-right me-2"></i> Cerrar sesión
                        </button>
                    </form>
                </div>
            </aside>
        }

        <main class="flex-grow-1 content">
            <div class="container-fluid p-4 p-md-5">
                @if (TempData["Ok"] is not null) {
                    <div class="alert alert-success border-0" style="background:rgba(34,197,94,.14);color:#dcfce7;">
                        <i class="bi bi-check-circle me-2"></i>@TempData["Ok"]
                    </div>
                }
                @if (TempData["Err"] is not null) {
                    <div class="alert alert-danger border-0" style="background:rgba(239,68,68,.14);color:#fee2e2;">
                        <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Err"]
                    </div>
                }

                @RenderBody()
            </div>
        </main>
    </div>

    <!-- ✅ ORDEN CORRECTO DE SCRIPTS -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"
            integrity="sha256-/JqT3SQfawRcv/BIHPThkBvs0OEvtFFmqPF/lYI/Cxo="
            crossorigin="anonymous"></script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Opcional pero recomendado si usas validación unobtrusive -->
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.5/dist/jquery.validate.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation-unobtrusive@4.0.0/dist/jquery.validate.unobtrusive.min.js"></script>

    @RenderSection("Scripts", required: false)
</body>
</html>