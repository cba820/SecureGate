// reverseproxy.json
{
  "ReverseProxy": {
    "Routes": {
      "apicertificado_all": {
        "ClusterId": "apicertificado_cluster",
        "Match": {
          "Path": "/apicertificado/{**catch-all}"
        },
        "AuthorizationPolicy": "ProxyPolicy",
        "Transforms": [
          { "PathPattern": "/{**catch-all}" }
        ]
      }
    },
    "Clusters": {
      "apicertificado_cluster": {
        "Destinations": {
          "d1": {
            "Address": "http://172.20.1.21:9533/"
          }
        }
      }
    }
  }
}
